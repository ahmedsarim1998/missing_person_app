# locAIte backend configuration. Copy to backend/.env and fill in real values.
# Anything left unset falls back to a safe default (secrets are auto-generated
# and persisted to backend/instance/ if not provided here).

# development | production | testing
APP_ENV=production

# Secrets — set strong unique values in production. If omitted, a random secret
# is generated once and stored in backend/instance/secret.key & jwt.key.
SECRET_KEY=
JWT_SECRET_KEY=

# Access-token lifetime in minutes (default 720 = 12h)
JWT_EXPIRES_MIN=720

# Seed administrator. If ADMIN_PASSWORD is blank a random one is generated and
# printed to the server log ONCE on first boot — change it immediately.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@locaite.com
ADMIN_PASSWORD=

# Comma-separated allowed CORS origins (the site is same-origin by default).
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# Camera for the live stream: 0 = default webcam, or an RTSP/HTTP URL.
CAMERA_SOURCE=0

# Login throttle
LOGIN_MAX_ATTEMPTS=10
LOGIN_WINDOW_SECONDS=300

# Upload limit (MB)
MAX_CONTENT_LENGTH_MB=25

# Logging
LOG_LEVEL=INFO

# Waitress server
HOST=0.0.0.0
PORT=5000
THREADS=8

# Facebook analyzer (optional — only needed to scrape a real source)
FB_GROUP=
FB_PAGES=2
FB_COOKIES=
